# Public Supabase settings used by the browser and SSR build.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase settings. These may use the same URL/publishable key above.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Advisor access. Keep this server-only and use a long, random value.
ADVISOR_PASSCODE=

# Contract Decoder AI settings. AI_BASE_URL may point to any OpenAI-compatible API.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=
# Set to false only when the selected OpenAI-compatible provider lacks JSON-schema outputs.
AI_STRUCTURED_OUTPUTS=true
