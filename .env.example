# Public Supabase settings used by the browser and SSR build.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase settings. These may use the same URL/publishable key above.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Advisor access. Keep this server-only and use a long, random value.
ADVISOR_PASSCODE=

# Optional YouTube Data API key. Video embeds work without it; this only enables public comments.
YOUTUBE_API_KEY=

# Generic OpenAI-compatible fallback used when feature-specific values below are empty.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=
AI_STRUCTURED_OUTPUTS=true

# Limited support AI. A small free-tier model is appropriate.
SUPPORT_AI_API_KEY=
SUPPORT_AI_BASE_URL=
SUPPORT_AI_MODEL=

# Contract Decoder AI. This can use a different small model/provider.
DECODER_AI_API_KEY=
DECODER_AI_BASE_URL=
DECODER_AI_MODEL=
DECODER_AI_STRUCTURED_OUTPUTS=true

# Optional private salt for hashing anonymous AI rate-limit identities.
AI_RATE_LIMIT_SALT=
